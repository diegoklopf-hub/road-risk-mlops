      "title": "Aperçu temps réel",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#F2495C", "value": null },
            { "color": "#FF9830", "value": 0.9 },
            { "color": "#73BF69", "value": 0.98 }
          ]},
          "unit": "percentunit", "min": 0, "max": 1, "decimals": 3
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "Prometheus" }, "expr": "rate(ml_prediction_total{status=\"success\"}[5m]) / rate(ml_prediction_total[5m])", "instant": true, "legendFormat": "Taux succès", "refId": "A" }],
      "title": "Taux succès (5m)", "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
