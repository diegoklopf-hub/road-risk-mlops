      "targets": [{ "datasource": { "type": "prometheus", "uid": "Prometheus" }, "expr": "rate(ml_prediction_payload_cities_count_sum[5m]) / rate(ml_prediction_payload_cities_count_count[5m])", "instant": true, "legendFormat": "Villes moy.", "refId": "A" }],
      "title": "Villes / requête (5m)", "type": "stat"
